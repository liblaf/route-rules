{
  "files.exclude": {
    "**/__pycache__/": true,
    "**/.cache/": true,
    "**/.codspeed/": true,
    "**/.coverage": true,
    "**/.coverage.*": true,
    "**/.grimp_cache/": true,
    "**/.hypothesis/": true,
    "**/.import_linter_cache/": true,
    "**/.nox/": true,
    "**/.pixi/": true,
    "**/.pytest_cache/": true,
    "**/.ruff_cache/": true,
    "**/.venv/": true,
    "**/dist/": true,
    "**/junit.xml": true,
    "**/site/": true
  },
  "python.testing.pytestArgs": ["--color=yes", "--cov"],
  "python.testing.pytestEnabled": true
}
